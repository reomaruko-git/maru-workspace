<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.cathackstudio.fx-luce</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/python3</string>
        <string>/Users/luce/projects/fx-luce/auto_trader.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/luce/projects/fx-luce</string>

    <key>UserName</key>
    <string>luce</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/luce/projects/fx-luce/auto_trader.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/luce/projects/fx-luce/auto_trader.log</string>

    <key>ThrottleInterval</key>
    <integer>30</integer>
</dict>
</plist>
